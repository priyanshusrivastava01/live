# Server Configuration
PORT=5000

# MongoDB Database Connection String
# Replace with your actual local MongoDB URI (e.g. mongodb://localhost:27017/salesoverflow) or MongoDB Atlas URI.
MONGODB_URI=mongodb://localhost:27017/salesoverflow

# Email SMTP Notification Configuration (Optional)
# If provided, the backend will automatically send email alerts on new contact form submissions.
EMAIL_HOST=smtp.mailtrap.io
EMAIL_PORT=2525
EMAIL_SECURE=false
EMAIL_USER=your_smtp_username
EMAIL_PASS=your_smtp_password

# The email address that will receive the notification alerts
NOTIFICATION_EMAIL=contact@salesoverflow.in
